# Opción A: Google Gemini
LLM_PROVIDER=gemini
GEMINI_API_KEY=tu-api-key
LLM_STANDARD_MODEL=gemini/gemini-1.5-flash
LLM_PREMIUM_MODEL=gemini/gemini-1.5-pro

# Opción B: Anthropic Claude
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=tu-api-key
LLM_STANDARD_MODEL=claude-haiku-4-5-20251001
LLM_PREMIUM_MODEL=claude-sonnet-4-5

# Siempre disponible (local, costo $0)
LOCAL_MODEL=ollama/llama3.2

# GitHub
GITHUB_TOKEN=your-github-token-here
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# App
APP_ENV=development
APP_PORT=8000